{
    "name": "techork/payment-service-domain",
    "description": "Domain aggregates, events, commands and value objects for payment services",
    "type": "library",
    "license": "proprietary",
    "repositories": [
        {
            "type": "vcs",
            "url": "git@github.com:andreapalladiokiv/payment-service-common.git"
        }
    ],
    "require": {
        "php": "^8.4",
        "eventsauce/eventsauce": "^3.8",
        "moneyphp/money": "^4.0",
        "techork/payment-service-common": "@dev"
    },
    "require-dev": {
        "eventsauce/pest-utilities": "^3.4",
        "mockery/mockery": "^1.6",
        "pestphp/pest": "^3.0 || ^4.0"
    },
    "autoload": {
        "psr-4": {
            "Techork\\PaymentService\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Techork\\PaymentService\\Tests\\": "tests"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
